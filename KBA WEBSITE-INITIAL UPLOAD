            className="w-full border-b border-gray-200 py-2 focus:outline-none focus:border-accent-gold transition-colors font-body text-sm text-primary-dark"
            placeholder="John Doe"
          />
        </div>
        <div className="space-y-2">
          <label className="text-[10px] uppercase tracking-widest font-bold text-gray-500">Email Address</label>
          <input
