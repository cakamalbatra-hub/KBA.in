      <div className="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div className="space-y-2">
          <label className="text-[10px] uppercase tracking-widest font-bold text-gray-500">Phone Number</label>
          <input
            type="tel"
            value={formData.phone}
            onChange={(e) => setFormData({ ...formData, phone: e.target.value })}
            className="w-full border-b border-gray-200 py-2 focus:outline-none focus:border-accent-gold transition-colors font-body text-sm text-primary-dark"
            placeholder="+91 00000 00000"
          />
        </div>
        <div className="space-y-2">
          <label className="text-[10px] uppercase tracking-widest font-bold text-gray-500">Interest</label>
          <select
            value={formData.service}
            onChange={(e) => setFormData({ ...formData, service: e.target.value })}
            className="w-full border-b border-gray-200 py-2 focus:outline-none focus:border-accent-gold transition-colors font-body text-sm bg-transparent text-primary-dark"
          >
            <option value="India">Indian Services (Tax/Audit)</option>
            <option value="Global">International Services (UK/Canada)</option>
            <option value="Other">Other Advisory</option>
          </select>
        </div>
