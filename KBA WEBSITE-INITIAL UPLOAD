import React, { useState, useEffect, useRef } from 'react';
import { db, auth } from '../firebase';
import { collection, query, orderBy, onSnapshot, addDoc, serverTimestamp } from 'firebase/firestore';
import { Send, User, Lock } from 'lucide-react';
import { cn } from '../lib/utils';
import { handleFirestoreError, OperationType } from '../lib/firestore-error';

interface Message {
  id: string;
  clientId: string;
  clientName: string;
  clientEmail: string;
  senderId: string;
  senderRole: 'client' | 'partner';
  content: string;
  timestamp: any;
  read: boolean;
}

export const AdminMessages: React.FC = () => {
  const [messages, setMessages] = useState<Message[]>([]);
  const [selectedClientId, setSelectedClientId] = useState<string | null>(null);
  const [replyText, setReplyText] = useState('');
  const scrollRef = useRef<HTMLDivElement>(null);

  useEffect(() => {
    const q = query(collection(db, 'messages'), orderBy('timestamp', 'asc'));
    const unsubscribe = onSnapshot(q, (snapshot) => {
      const msgs: Message[] = [];
      snapshot.forEach((doc) => {
        msgs.push({ id: doc.id, ...doc.data() } as Message);
      });
      setMessages(msgs);
      
      if (scrollRef.current) {
        setTimeout(() => {
          scrollRef.current!.scrollTop = scrollRef.current!.scrollHeight;
        }, 100);
      }
    }, (error) => {
      handleFirestoreError(error, OperationType.GET, 'messages', auth);
    });

    return () => unsubscribe();
  }, []);

  // Group messages by client
  const clients = Array.from(new Set(messages.map(m => m.clientId))).map(clientId => {
    const clientMessages = messages.filter(m => m.clientId === clientId);
    const lastMessage = clientMessages[clientMessages.length - 1];
    return {
      id: clientId,
      name: lastMessage.clientName,
      email: lastMessage.clientEmail,
      lastMessageTime: lastMessage.timestamp,
      unreadCount: clientMessages.filter(m => m.senderRole === 'client' && !m.read).length
    };
  }).sort((a, b) => {
    if (!a.lastMessageTime || !b.lastMessageTime) return 0;
    return b.lastMessageTime.toMillis() - a.lastMessageTime.toMillis();
  });

  const selectedClientMessages = messages.filter(m => m.clientId === selectedClientId);
  const selectedClientInfo = clients.find(c => c.id === selectedClientId);

  const handleSendReply = async (e: React.FormEvent) => {
    e.preventDefault();
    if (!replyText.trim() || !selectedClientId || !auth.currentUser) return;

    const content = replyText.trim();
    setReplyText('');

    try {
      await addDoc(collection(db, 'messages'), {
        clientId: selectedClientId,
        clientName: selectedClientInfo?.name || 'Client',
        clientEmail: selectedClientInfo?.email || '',
        senderId: auth.currentUser.uid,
        senderRole: 'partner',
        content: content,
        timestamp: serverTimestamp(),
        read: false
      });
    } catch (error) {
      handleFirestoreError(error, OperationType.CREATE, 'messages', auth);
    }
  };

  return (
    <div className="bg-white ledger-border shadow-sm overflow-hidden flex h-[600px]">
      {/* Client List */}
      <div className="w-1/3 border-r border-primary-dark/10 flex flex-col bg-gray-50">
        <div className="p-4 border-b border-primary-dark/10 bg-white">
          <h2 className="text-lg font-serif text-primary-dark flex items-center">
            <Lock className="w-4 h-4 mr-2 text-accent-gold" />
            Secure Messages
          </h2>
        </div>
        <div className="flex-1 overflow-y-auto custom-scrollbar">
          {clients.length === 0 ? (
            <div className="p-6 text-center text-gray-400 text-sm italic">
              No messages yet.
            </div>
          ) : (
            clients.map(client => (
              <button
                key={client.id}
                onClick={() => setSelectedClientId(client.id)}
                className={cn(
                  "w-full text-left p-4 border-b border-primary-dark/5 hover:bg-white transition-colors flex items-start space-x-3",
                  selectedClientId === client.id ? "bg-white border-l-4 border-l-accent-gold" : "border-l-4 border-l-transparent"
                )}
              >
                <div className="w-10 h-10 rounded-full bg-primary-dark/5 flex items-center justify-center shrink-0 text-primary-dark font-bold">
                  {client.name.charAt(0).toUpperCase()}
                </div>
                <div className="flex-1 min-w-0">
                  <div className="flex justify-between items-baseline">
                    <h3 className="text-sm font-bold text-primary-dark truncate">{client.name}</h3>
                    <span className="text-[10px] text-gray-400 whitespace-nowrap ml-2">
                      {client.lastMessageTime?.toDate().toLocaleDateString(undefined, { month: 'short', day: 'numeric' })}
                    </span>
                  </div>
                  <p className="text-xs text-gray-500 truncate">{client.email}</p>
                </div>
              </button>
            ))
          )}
        </div>
      </div>

      {/* Chat Area */}
      <div className="w-2/3 flex flex-col bg-white">
        {selectedClientId ? (
          <>
            <div className="p-4 border-b border-primary-dark/10 bg-white flex items-center space-x-3">
              <div className="w-10 h-10 rounded-full bg-primary-dark/5 flex items-center justify-center shrink-0 text-primary-dark font-bold">
                {selectedClientInfo?.name.charAt(0).toUpperCase()}
              </div>
              <div>
                <h3 className="text-sm font-bold text-primary-dark">{selectedClientInfo?.name}</h3>
                <p className="text-xs text-gray-500">{selectedClientInfo?.email}</p>
              </div>
            </div>

            <div 
              ref={scrollRef}
              className="flex-1 overflow-y-auto p-6 space-y-4 custom-scrollbar bg-bg-cream/30"
            >
              {selectedClientMessages.map((msg) => (
                <div 
                  key={msg.id}
                  className={cn(
                    "flex flex-col max-w-[80%]",
                    msg.senderRole === 'partner' ? "ml-auto items-end" : "mr-auto items-start"
                  )}
                >
                  <div className={cn(
                    "p-4 text-sm leading-relaxed shadow-sm",
                    msg.senderRole === 'partner' 
                      ? "bg-primary-dark text-white rounded-l-xl rounded-tr-xl" 
                      : "bg-white text-gray-800 rounded-r-xl rounded-tl-xl border border-gray-200"
                  )}>
                    {msg.content}
                  </div>
                  <span className="text-[10px] uppercase tracking-wider text-gray-400 mt-1 font-bold">
                    {msg.senderRole === 'partner' ? 'You' : msg.clientName} • {msg.timestamp?.toDate().toLocaleTimeString([], {hour: '2-digit', minute:'2-digit'}) || 'Just now'}
                  </span>
                </div>
              ))}
            </div>

            <form onSubmit={handleSendReply} className="p-4 bg-gray-50 border-t border-gray-100">
              <div className="relative flex items-center">
                <input
                  type="text"
                  value={replyText}
                  onChange={(e) => setReplyText(e.target.value)}
                  placeholder="Type your reply..."
                  className="w-full pl-4 pr-12 py-3 text-sm bg-white border border-gray-200 rounded-sm focus:outline-none focus:border-accent-gold transition-colors"
                />
                <button 
                  type="submit"
                  disabled={!replyText.trim()}
                  className="absolute right-2 p-2 text-primary-dark hover:text-accent-gold transition-colors disabled:opacity-30"
                >
                  <Send className="w-5 h-5" />
                </button>
              </div>
            </form>
          </>
        ) : (
          <div className="flex-1 flex flex-col items-center justify-center text-gray-400 space-y-4">
            <Lock className="w-12 h-12 opacity-20" />
            <p className="text-sm uppercase tracking-widest font-bold">Select a client to view messages</p>
          </div>
        )}
      </div>
    </div>
  );
};

