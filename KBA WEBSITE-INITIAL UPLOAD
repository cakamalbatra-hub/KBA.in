          onChange={(e) => setFormData({ ...formData, message: e.target.value })}
          className="w-full border border-gray-200 p-4 focus:outline-none focus:border-accent-gold transition-colors font-body text-sm resize-none text-primary-dark rounded-sm"
          placeholder="How can we help you?"
        />
      </div>

      <button
        type="submit"
        disabled={status === 'submitting'}
        className="w-full bg-accent-gold text-white py-4 font-bold uppercase tracking-widest text-sm hover:bg-primary-dark transition-colors flex items-center justify-center space-x-2 disabled:opacity-50 rounded-sm"
      >
        <span>{status === 'submitting' ? 'Sending...' : 'Send Inquiry'}</span>
        <Send className="w-4 h-4" />
      </button>
      
      {status === 'error' && (
        <p className="text-[10px] text-red-500 text-center font-bold uppercase tracking-widest">
          Failed to send. Please try again or call us directly.
